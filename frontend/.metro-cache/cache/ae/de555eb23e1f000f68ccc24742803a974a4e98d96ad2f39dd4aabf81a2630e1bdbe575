{"dependencies":[],"output":[{"data":{"code":"__d(function(global, require, _importDefaultUnused, _importAllUnused, module, exports, _dependencyMapUnused) {\n  module.exports = {\n  \"bhagat-singh\": {\n    \"name\": \"Bhagat Singh\",\n    \"questions\": [\n      {\n        \"id\": \"bs_q1\",\n        \"question\": \"Why were you so brave?\",\n        \"answer\": \"I was brave because I loved India more than I loved myself! When you believe in something truly important, fear just disappears.\",\n        \"badge\": \"Courage Unlocked! 🔥\"\n      },\n      {\n        \"id\": \"bs_q2\",\n        \"question\": \"What did you study?\",\n        \"answer\": \"I loved reading books about freedom and justice from all over the world! I believed that knowledge was the most powerful weapon of all.\",\n        \"badge\": \"Bookworm Badge! 📚\"\n      },\n      {\n        \"id\": \"bs_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a very curious and serious child! Even at 12, I visited a battlefield and promised myself I would free India one day.\",\n        \"badge\": \"Young Hero! ⭐\"\n      },\n      {\n        \"id\": \"bs_q4\",\n        \"question\": \"What is Inquilab Zindabad?\",\n        \"answer\": \"It means Long Live the Revolution! I wanted every Indian to rise up and fight for freedom together. Say it loud — Inquilab Zindabad!\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"rani-lakshmibai\": {\n    \"name\": \"Rani Lakshmibai\",\n    \"questions\": [\n      {\n        \"id\": \"rl_q1\",\n        \"question\": \"Why did you fight for Jhansi?\",\n        \"answer\": \"Jhansi was my home and my people needed me! A true leader never abandons their family when they are in danger.\",\n        \"badge\": \"Protector Badge! 🛡️\"\n      },\n      {\n        \"id\": \"rl_q2\",\n        \"question\": \"Did you really ride a horse?\",\n        \"answer\": \"Yes! I learned to ride horses, use a sword and shoot arrows when I was young — just like you learn your school lessons! Practice makes perfect.\",\n        \"badge\": \"Warrior Spirit! ⚔️\"\n      },\n      {\n        \"id\": \"rl_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a very energetic and fearless girl! I trained with boys in sword fighting and horse riding instead of sitting quietly. I believed girls could do anything!\",\n        \"badge\": \"Girl Power! 🌸\"\n      },\n      {\n        \"id\": \"rl_q4\",\n        \"question\": \"What does Main apni Jhansi nahi doongi mean?\",\n        \"answer\": \"It means I will not give up my Jhansi! I said this to tell the British that I would never surrender my kingdom or my people to anyone.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"mahatma-gandhi\": {\n    \"name\": \"Mahatma Gandhi\",\n    \"questions\": [\n      {\n        \"id\": \"mg_q1\",\n        \"question\": \"Why did you never use weapons?\",\n        \"answer\": \"Because I believed love and truth are stronger than any weapon! When you fight with kindness and peace, you win not just the battle but also the hearts of people.\",\n        \"badge\": \"Peace Champion! 🕊️\"\n      },\n      {\n        \"id\": \"mg_q2\",\n        \"question\": \"What is the Salt March?\",\n        \"answer\": \"I walked 240 miles to the sea to make salt from seawater! It was my way of telling the British that Indians would not follow unjust rules anymore.\",\n        \"badge\": \"March On! 👣\"\n      },\n      {\n        \"id\": \"mg_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a very shy and quiet child who was even afraid of the dark! But I learned that courage is not about being fearless — it is about doing what is right even when you are scared.\",\n        \"badge\": \"Brave Heart! 💚\"\n      },\n      {\n        \"id\": \"mg_q4\",\n        \"question\": \"What does Do or Die mean?\",\n        \"answer\": \"It means we must either win freedom or give everything trying! I said this to inspire every Indian to be completely committed to independence.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"subhas-bose\": {\n    \"name\": \"Subhas Chandra Bose\",\n    \"questions\": [\n      {\n        \"id\": \"scb_q1\",\n        \"question\": \"Why did you build your own army?\",\n        \"answer\": \"Because I believed freedom had to be fought for with full strength! I formed the Indian National Army so Indians could stand up and fight together as soldiers.\",\n        \"badge\": \"Army Builder! 🦁\"\n      },\n      {\n        \"id\": \"scb_q2\",\n        \"question\": \"How did you escape from house arrest?\",\n        \"answer\": \"I disguised myself and secretly traveled thousands of miles across countries to build support for India's freedom! It was the greatest adventure of my life.\",\n        \"badge\": \"Escape Artist! 🌟\"\n      },\n      {\n        \"id\": \"scb_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was an excellent student who topped my university exams! But I loved India so much that I gave up a very comfortable government job to fight for freedom instead.\",\n        \"badge\": \"Brilliant Mind! 🎓\"\n      },\n      {\n        \"id\": \"scb_q4\",\n        \"question\": \"What does Give me blood mean?\",\n        \"answer\": \"I said give me blood and I will give you freedom! I meant that if Indians committed fully to the fight, together we would definitely win independence for our great nation.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"sarojini-naidu\": {\n    \"name\": \"Sarojini Naidu\",\n    \"questions\": [\n      {\n        \"id\": \"sn_q1\",\n        \"question\": \"Why are you called the Nightingale of India?\",\n        \"answer\": \"Because my poems were as beautiful as a nightingale's song! I used my writing to inspire Indians and show the world how wonderful our country truly is.\",\n        \"badge\": \"Poet's Heart! 🎵\"\n      },\n      {\n        \"id\": \"sn_q2\",\n        \"question\": \"How did you fight for freedom?\",\n        \"answer\": \"I gave powerful speeches, led marches and organized people across India! I believed that words and unity were the most powerful tools for change.\",\n        \"badge\": \"Voice of India! 📢\"\n      },\n      {\n        \"id\": \"sn_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a child who loved reading and writing poems in many languages! I wrote my first long poem when I was just 12 years old — not much older than you!\",\n        \"badge\": \"Child Prodigy! ✨\"\n      },\n      {\n        \"id\": \"sn_q4\",\n        \"question\": \"What is Vande Mataram?\",\n        \"answer\": \"It means I bow to thee Mother India! It is our beautiful song of love for India that filled every freedom fighter's heart with pride and courage.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"chandrashekhar-azad\": {\n    \"name\": \"Chandrashekhar Azad\",\n    \"questions\": [\n      {\n        \"id\": \"ca_q1\",\n        \"question\": \"Why did you call yourself Azad?\",\n        \"answer\": \"Azad means free! When a judge asked my name in court I said Azad, my father's name is Independence and my home is jail — because I refused to be a prisoner in my own country!\",\n        \"badge\": \"Freedom Name! 🕊️\"\n      },\n      {\n        \"id\": \"ca_q2\",\n        \"question\": \"What made you so fearless?\",\n        \"answer\": \"I made a promise to myself that I would never be captured alive by the British! When you make a promise you truly mean, it gives you the strength of ten people.\",\n        \"badge\": \"Unbreakable! 💪\"\n      },\n      {\n        \"id\": \"ca_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a wild and adventurous boy who loved climbing trees and running faster than anyone! My energy and speed later helped me outsmart the British many times.\",\n        \"badge\": \"Wild Child! 🌿\"\n      },\n      {\n        \"id\": \"ca_q4\",\n        \"question\": \"What is your most famous promise?\",\n        \"answer\": \"I promised I would never be caught alive — and I kept that promise until my very last day! A person who keeps their promises is the bravest person of all.\",\n        \"badge\": \"Promise Keeper! 🌟\"\n      }\n    ]\n  },\n  \"mangal-pandey\": {\n    \"name\": \"Mangal Pandey\",\n    \"questions\": [\n      {\n        \"id\": \"mp_q1\",\n        \"question\": \"Why are you called the first spark?\",\n        \"answer\": \"Because I was one of the first soldiers to stand up and say no to the British in 1857! One small spark can start a great fire of freedom.\",\n        \"badge\": \"First Spark! 🔥\"\n      },\n      {\n        \"id\": \"mp_q2\",\n        \"question\": \"What made you stand up to the British?\",\n        \"answer\": \"I was a proud Indian soldier and I refused to follow orders that hurt my beliefs and dignity! Self-respect is more important than any job or reward.\",\n        \"badge\": \"Self Respect! 🏅\"\n      },\n      {\n        \"id\": \"mp_q3\",\n        \"question\": \"What were you like as a soldier?\",\n        \"answer\": \"I was a very dedicated and disciplined soldier who took my duties very seriously! But I believed that duty to my country was more important than duty to a foreign ruler.\",\n        \"badge\": \"Brave Soldier! ⚔️\"\n      },\n      {\n        \"id\": \"mp_q4\",\n        \"question\": \"Why do we remember you today?\",\n        \"answer\": \"Because I showed that one ordinary person standing up for what is right can change history forever! You are never too small to make a big difference.\",\n        \"badge\": \"History Maker! 📖\"\n      }\n    ]\n  },\n  \"tilak\": {\n    \"name\": \"Bal Gangadhar Tilak\",\n    \"questions\": [\n      {\n        \"id\": \"bgt_q1\",\n        \"question\": \"What does Swaraj is my birthright mean?\",\n        \"answer\": \"It means freedom belongs to every Indian simply because we were born here! Nobody can take away what is naturally and rightfully yours.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      },\n      {\n        \"id\": \"bgt_q2\",\n        \"question\": \"How did you use festivals for freedom?\",\n        \"answer\": \"I turned the Ganesh festival into huge community gatherings where thousands of Indians could meet, talk and plan together! Celebrations can be powerful tools for change.\",\n        \"badge\": \"Festival Power! 🎊\"\n      },\n      {\n        \"id\": \"bgt_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a very sharp student who loved mathematics and Sanskrit! I believed education was the key to everything — and I spent my whole life teaching and learning.\",\n        \"badge\": \"Scholar Badge! 📐\"\n      },\n      {\n        \"id\": \"bgt_q4\",\n        \"question\": \"Why did you start a newspaper?\",\n        \"answer\": \"Because I wanted to spread the message of freedom to every corner of India! A newspaper reaches thousands of people and powerful words can change the world.\",\n        \"badge\": \"Word Power! 📰\"\n      }\n    ]\n  },\n  \"sardar-patel\": {\n    \"name\": \"Sardar Vallabhbhai Patel\",\n    \"questions\": [\n      {\n        \"id\": \"sp_q1\",\n        \"question\": \"Why are you called the Iron Man?\",\n        \"answer\": \"Because I was as strong and determined as iron! When I made up my mind to do something for India, absolutely nothing could stop me.\",\n        \"badge\": \"Iron Will! 💪\"\n      },\n      {\n        \"id\": \"sp_q2\",\n        \"question\": \"How did you unite India?\",\n        \"answer\": \"After independence I convinced over 500 small kingdoms to join together as one India! I used patience, strength and love for my country to bring everyone together.\",\n        \"badge\": \"Unifier! 🗺️\"\n      },\n      {\n        \"id\": \"sp_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a very determined child who faced every challenge without complaining! Once I had a painful boil but I treated it myself with a hot iron rod — that is how tough I was!\",\n        \"badge\": \"Tough as Iron! 🔩\"\n      },\n      {\n        \"id\": \"sp_q4\",\n        \"question\": \"What is the Statue of Unity?\",\n        \"answer\": \"It is the world's tallest statue built to honour me in Gujarat! It stands 182 metres tall — as tall as my dream of a united and strong India.\",\n        \"badge\": \"Giant Legacy! 🗽\"\n      }\n    ]\n  },\n  \"birsa-munda\": {\n    \"name\": \"Birsa Munda\",\n    \"questions\": [\n      {\n        \"id\": \"bm_q1\",\n        \"question\": \"Why do people call you Bhagwan?\",\n        \"answer\": \"The people of my tribe called me Bhagwan because I fought so hard to protect them and their forests! When you dedicate your life to helping others they see something divine in you.\",\n        \"badge\": \"Forest God! 🌿\"\n      },\n      {\n        \"id\": \"bm_q2\",\n        \"question\": \"What did you fight for?\",\n        \"answer\": \"I fought for my people's land, their forests and their right to live freely! The British were taking everything from tribal people and I said enough — this must stop.\",\n        \"badge\": \"Land Guardian! 🌍\"\n      },\n      {\n        \"id\": \"bm_q3\",\n        \"question\": \"What were you like as a kid?\",\n        \"answer\": \"I was a playful boy who loved roaming the forests and playing the flute! The forest was my school and every tree and animal was my teacher.\",\n        \"badge\": \"Forest Child! 🎵\"\n      },\n      {\n        \"id\": \"bm_q4\",\n        \"question\": \"What is your biggest legacy?\",\n        \"answer\": \"I showed that tribal people deserve the same rights and respect as everyone else! Today Jharkhand celebrates my birthday as a public holiday — that makes me very proud.\",\n        \"badge\": \"Tribal Hero! 🏹\"\n      }\n    ]\n  },\n  \"rani-gaidinliu\": {\n    \"name\": \"Rani Gaidinliu\",\n    \"questions\": [\n      {\n        \"id\": \"rg_q1\",\n        \"question\": \"How old were you when you started fighting?\",\n        \"answer\": \"I was only 13 years old when I joined the freedom movement! Age is just a number — what matters is the fire in your heart.\",\n        \"badge\": \"Young Warrior! ⭐\"\n      },\n      {\n        \"id\": \"rg_q2\",\n        \"question\": \"What did you fight for?\",\n        \"answer\": \"I fought for the freedom and culture of my Naga people in the Northeast! Every community in India deserves to be free and proud of who they are.\",\n        \"badge\": \"Culture Keeper! 🌺\"\n      },\n      {\n        \"id\": \"rg_q3\",\n        \"question\": \"What were you like as a teenager?\",\n        \"answer\": \"I was a fearless teenager who inspired thousands of adults to follow me! I proved that young people can lead and make a real difference in the world.\",\n        \"badge\": \"Teen Leader! 🌟\"\n      },\n      {\n        \"id\": \"rg_q4\",\n        \"question\": \"What did Nehru call you?\",\n        \"answer\": \"Jawaharlal Nehru called me the Daughter of the Hills! He recognised my bravery and gave me the title Rani which means Queen — and I wore that name with great pride.\",\n        \"badge\": \"Queen of Hills! 👑\"\n      }\n    ]\n  },\n  \"matangini-hazra\": {\n    \"name\": \"Matangini Hazra\",\n    \"questions\": [\n      {\n        \"id\": \"mh_q1\",\n        \"question\": \"How old were you when you became a hero?\",\n        \"answer\": \"I was 73 years old! It is never too late to be brave and do something great for your country. Age never stopped me from loving India.\",\n        \"badge\": \"Ageless Courage! 🌸\"\n      },\n      {\n        \"id\": \"mh_q2\",\n        \"question\": \"What happened when you carried the flag?\",\n        \"answer\": \"Even when I was hurt I kept holding the Indian flag high and kept walking forward! I kept saying Vande Mataram with every step because I would not let the flag fall.\",\n        \"badge\": \"Flag Bearer! 🇮🇳\"\n      },\n      {\n        \"id\": \"mh_q3\",\n        \"question\": \"Why do people call you Gandhi Buri?\",\n        \"answer\": \"Gandhi Buri means Old Lady Gandhi! People called me this because I followed Gandhiji's peaceful path with my whole heart and soul.\",\n        \"badge\": \"Gandhi's Spirit! 🕊️\"\n      },\n      {\n        \"id\": \"mh_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Never think you are too small, too young or too old to do something amazing! I was a grandmother who became a hero — and so can you in your own special way.\",\n        \"badge\": \"Inspiration! ✨\"\n      }\n    ]\n  },\n  \"tantia-tope\": {\n    \"name\": \"Tantia Tope\",\n    \"questions\": [\n      {\n        \"id\": \"tt_q1\",\n        \"question\": \"Why were you such a great general?\",\n        \"answer\": \"Because I never gave up even when things looked impossible! A great leader finds a new way forward when one path is blocked — I always found another way to fight.\",\n        \"badge\": \"Master General! ⚔️\"\n      },\n      {\n        \"id\": \"tt_q2\",\n        \"question\": \"How did you help Rani Lakshmibai?\",\n        \"answer\": \"I was her most trusted commander and fought alongside her to defend Jhansi! True friendship means standing with someone in their most difficult moment.\",\n        \"badge\": \"Loyal Friend! 🤝\"\n      },\n      {\n        \"id\": \"tt_q3\",\n        \"question\": \"What made you a great warrior?\",\n        \"answer\": \"I could move my army very quickly and surprise the enemy when they least expected it! In battle, being clever is just as important as being strong.\",\n        \"badge\": \"Swift Warrior! 💨\"\n      },\n      {\n        \"id\": \"tt_q4\",\n        \"question\": \"What is your biggest legacy?\",\n        \"answer\": \"I showed that ordinary Indians could take on the most powerful army in the world and make them struggle! Courage and clever thinking can overcome any obstacle.\",\n        \"badge\": \"Clever Hero! 🧠\"\n      }\n    ]\n  },\n  \"alluri-sitarama-raju\": {\n    \"name\": \"Alluri Sitarama Raju\",\n    \"questions\": [\n      {\n        \"id\": \"asr_q1\",\n        \"question\": \"Why did you fight from the forest?\",\n        \"answer\": \"The forest was my home and my strength! I knew every tree and path in the jungle and used that knowledge to protect my tribal people from the British.\",\n        \"badge\": \"Forest Fighter! 🌳\"\n      },\n      {\n        \"id\": \"asr_q2\",\n        \"question\": \"Who were you fighting to protect?\",\n        \"answer\": \"I fought for the Adivasi tribal people of Andhra Pradesh whose land and rights were being taken away! Protecting the weak is the duty of every strong person.\",\n        \"badge\": \"Protector! 🛡️\"\n      },\n      {\n        \"id\": \"asr_q3\",\n        \"question\": \"What were you like as a young man?\",\n        \"answer\": \"I was a very spiritual and fearless young man who people believed had special powers! My courage inspired thousands of tribal people to rise up and fight together.\",\n        \"badge\": \"Mystic Hero! 🌟\"\n      },\n      {\n        \"id\": \"asr_q4\",\n        \"question\": \"What do people call you?\",\n        \"answer\": \"People call me Manyam Veerudu which means Hero of the Jungle! I am so proud that my people remember me with so much love and respect even today.\",\n        \"badge\": \"Jungle Hero! 🏹\"\n      }\n    ]\n  },\n  \"kanaklata-barua\": {\n    \"name\": \"Kanaklata Barua\",\n    \"questions\": [\n      {\n        \"id\": \"kb_q1\",\n        \"question\": \"How old were you when you became a hero?\",\n        \"answer\": \"I was only 17 years old! I carried the Indian flag in a procession and walked forward even when it was dangerous because I loved India with all my heart.\",\n        \"badge\": \"Teen Hero! ⭐\"\n      },\n      {\n        \"id\": \"kb_q2\",\n        \"question\": \"Why did you carry the flag?\",\n        \"answer\": \"Because the Indian flag represents our freedom and dignity! Whoever carries the flag carries the hopes and dreams of every single Indian — that gave me great strength.\",\n        \"badge\": \"Flag Pride! 🇮🇳\"\n      },\n      {\n        \"id\": \"kb_q3\",\n        \"question\": \"What were you like as a teenager?\",\n        \"answer\": \"I was a passionate and patriotic young girl who dreamed of a free India! I believed young people have a special responsibility to fight for a better future.\",\n        \"badge\": \"Patriot! 🌺\"\n      },\n      {\n        \"id\": \"kb_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Your age does not limit your courage! I was a teenager just like you will be one day — and I showed that young people can be true heroes for their country.\",\n        \"badge\": \"Young Legend! 🏅\"\n      }\n    ]\n  },\n  \"kunwar-singh\": {\n    \"name\": \"Kunwar Singh\",\n    \"questions\": [\n      {\n        \"id\": \"ks_q1\",\n        \"question\": \"How old were you when you went to war?\",\n        \"answer\": \"I was nearly 80 years old! People thought I was too old to fight but I showed them that the spirit of a warrior never grows old.\",\n        \"badge\": \"Ageless Warrior! 💪\"\n      },\n      {\n        \"id\": \"ks_q2\",\n        \"question\": \"What is your most amazing story?\",\n        \"answer\": \"When my arm was hurt in battle I cut it off myself and offered it to Mother Ganga before fighting on! That is how strong my will to fight for India truly was.\",\n        \"badge\": \"Incredible Strength! 🔥\"\n      },\n      {\n        \"id\": \"ks_q3\",\n        \"question\": \"What made you fight at 80?\",\n        \"answer\": \"Love for my country has no age limit! When your motherland needs you, you answer the call no matter how old or young you are.\",\n        \"badge\": \"Forever Young! ❤️\"\n      },\n      {\n        \"id\": \"ks_q4\",\n        \"question\": \"What is Har Har Mahadev?\",\n        \"answer\": \"It is the ancient battle cry meaning Victory to Lord Shiva! My soldiers and I shouted it as we charged into battle — it filled our hearts with fearless energy.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"veer-surendra-sai\": {\n    \"name\": \"Veer Surendra Sai\",\n    \"questions\": [\n      {\n        \"id\": \"vss_q1\",\n        \"question\": \"How long did you fight the British?\",\n        \"answer\": \"I fought for over 40 years — almost my entire life! True dedication means never giving up even when the struggle takes a very very long time.\",\n        \"badge\": \"Lifelong Fighter! ⏳\"\n      },\n      {\n        \"id\": \"vss_q2\",\n        \"question\": \"What did you fight for?\",\n        \"answer\": \"I fought for Odisha's independence and the rights of my people! Every region of India has its own heroes who protected their land with great love.\",\n        \"badge\": \"Odisha's Pride! 🌊\"\n      },\n      {\n        \"id\": \"vss_q3\",\n        \"question\": \"What made you a hero?\",\n        \"answer\": \"I never accepted defeat no matter how many times the British tried to stop me! Persistence — never giving up — is the most powerful quality any person can have.\",\n        \"badge\": \"Never Give Up! 🏆\"\n      },\n      {\n        \"id\": \"vss_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Never let anyone tell you that your dreams are too big or your fight is impossible! I proved that one determined person can keep the flame of freedom burning for decades.\",\n        \"badge\": \"Eternal Flame! 🔥\"\n      }\n    ]\n  },\n  \"pazhassi-raja\": {\n    \"name\": \"Pazhassi Raja\",\n    \"questions\": [\n      {\n        \"id\": \"pr_q1\",\n        \"question\": \"Why are you called the Lion of Kerala?\",\n        \"answer\": \"Because I was as fierce and proud as a lion protecting his territory! I fought from the deep forests of Kerala with the roar of a true jungle king.\",\n        \"badge\": \"Lion's Roar! 🦁\"\n      },\n      {\n        \"id\": \"pr_q2\",\n        \"question\": \"How did you fight the British?\",\n        \"answer\": \"I used guerrilla warfare — hiding in forests and striking when the enemy least expected it! Sometimes being clever and quick is better than having the biggest army.\",\n        \"badge\": \"Clever Warrior! 🌿\"\n      },\n      {\n        \"id\": \"pr_q3\",\n        \"question\": \"What made Kerala proud of you?\",\n        \"answer\": \"I was one of the first rulers in all of India to seriously challenge the British East India Company! Kerala has always been a land of brave and brilliant people.\",\n        \"badge\": \"Kerala's Pride! 🥥\"\n      },\n      {\n        \"id\": \"pr_q4\",\n        \"question\": \"What is your biggest lesson?\",\n        \"answer\": \"Know your home ground better than anyone else! I used Kerala's forests and hills as my greatest weapon — your strengths are always your best tools.\",\n        \"badge\": \"Home Advantage! 🏔️\"\n      }\n    ]\n  },\n  \"kattabomman\": {\n    \"name\": \"Veerapandiya Kattabomman\",\n    \"questions\": [\n      {\n        \"id\": \"vpk_q1\",\n        \"question\": \"Why did you refuse to pay taxes?\",\n        \"answer\": \"Because paying taxes to foreign rulers meant accepting that they owned our land! I said no because Tamil Nadu belongs to Tamil people — not to anyone who sails in from far away.\",\n        \"badge\": \"Defiant Hero! 💪\"\n      },\n      {\n        \"id\": \"vpk_q2\",\n        \"question\": \"What made you a great chieftain?\",\n        \"answer\": \"I was loyal to my people and bold in standing up for their rights! A true leader puts the welfare of their people before their own comfort and safety.\",\n        \"badge\": \"People's Chief! 👑\"\n      },\n      {\n        \"id\": \"vpk_q3\",\n        \"question\": \"Why is Tamil Nadu proud of you?\",\n        \"answer\": \"Because I was one of the first leaders in South India to openly defy the British! My bravery inspired generations of freedom fighters who came after me.\",\n        \"badge\": \"Tamil Pride! 🌺\"\n      },\n      {\n        \"id\": \"vpk_q4\",\n        \"question\": \"What is your famous quote?\",\n        \"answer\": \"I said I will not surrender! These three words carry the spirit of every freedom fighter who ever lived — never bow to injustice no matter what.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"tirot-sing\": {\n    \"name\": \"U Tirot Sing\",\n    \"questions\": [\n      {\n        \"id\": \"uts_q1\",\n        \"question\": \"Where did you come from?\",\n        \"answer\": \"I was a brave chief from the Khasi Hills of Meghalaya in Northeast India! Every corner of our great country has heroes who fought with equal passion for freedom.\",\n        \"badge\": \"Northeast Pride! 🏔️\"\n      },\n      {\n        \"id\": \"uts_q2\",\n        \"question\": \"How did you protect your people?\",\n        \"answer\": \"I used the misty hills and forests of Meghalaya as my shield and fought to keep my people free! Nature can be your greatest ally when you know how to use it.\",\n        \"badge\": \"Hill Guardian! 🌫️\"\n      },\n      {\n        \"id\": \"uts_q3\",\n        \"question\": \"Why do we remember you?\",\n        \"answer\": \"Because I showed that even small communities in faraway hills stood up to the British with great dignity and pride! Every act of bravery matters in history.\",\n        \"badge\": \"Hills Hero! ⭐\"\n      },\n      {\n        \"id\": \"uts_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"No matter where you come from — big city or small village, plains or mountains — you can be a hero for your people! India's strength is in every one of its children.\",\n        \"badge\": \"Every Hero Counts! 🇮🇳\"\n      }\n    ]\n  },\n  \"begum-hazrat-mahal\": {\n    \"name\": \"Begum Hazrat Mahal\",\n    \"questions\": [\n      {\n        \"id\": \"bhm_q1\",\n        \"question\": \"How did you become a leader?\",\n        \"answer\": \"When the British took my husband away I stepped forward and led Lucknow myself! True leaders rise up exactly when their people need them most.\",\n        \"badge\": \"Rising Leader! 👑\"\n      },\n      {\n        \"id\": \"bhm_q2\",\n        \"question\": \"What did you fight for?\",\n        \"answer\": \"I fought for Lucknow and for the dignity of every Indian! I refused to accept that a foreign power could simply walk in and take over our beautiful land.\",\n        \"badge\": \"City Defender! 🏰\"\n      },\n      {\n        \"id\": \"bhm_q3\",\n        \"question\": \"What made you special among freedom fighters?\",\n        \"answer\": \"I was a woman who led an entire army at a time when people thought only men could be warriors! I proved that courage has nothing to do with whether you are a boy or a girl.\",\n        \"badge\": \"Barrier Breaker! 🌟\"\n      },\n      {\n        \"id\": \"bhm_q4\",\n        \"question\": \"What is your message for girls?\",\n        \"answer\": \"Never let anyone tell you what you cannot do because you are a girl! I led soldiers, made decisions and fought for my people — and so can you in your own amazing way.\",\n        \"badge\": \"Girl Power! 🌸\"\n      }\n    ]\n  },\n  \"kittur-chennamma\": {\n    \"name\": \"Kittur Chennamma\",\n    \"questions\": [\n      {\n        \"id\": \"kc_q1\",\n        \"question\": \"Why are you a pioneer?\",\n        \"answer\": \"Because I was the first woman in India to take up arms against the British — long before many other famous freedom fighters were even born! Being first takes the most courage.\",\n        \"badge\": \"Trailblazer! 🔥\"\n      },\n      {\n        \"id\": \"kc_q2\",\n        \"question\": \"What did you defend?\",\n        \"answer\": \"I defended my kingdom of Kittur in Karnataka with everything I had! A true ruler fights for their kingdom and their people until their very last breath.\",\n        \"badge\": \"Kingdom Defender! 🛡️\"\n      },\n      {\n        \"id\": \"kc_q3\",\n        \"question\": \"What made you brave?\",\n        \"answer\": \"My love for my people was stronger than my fear! When you truly love something you find a courage inside yourself that you never knew existed.\",\n        \"badge\": \"Love's Courage! ❤️\"\n      },\n      {\n        \"id\": \"kc_q4\",\n        \"question\": \"What is Karnataka's pride in you?\",\n        \"answer\": \"Karnataka celebrates me as a true daughter who fought with honour! Every state in India has heroes — knowing your local heroes makes you even more proud of where you come from.\",\n        \"badge\": \"Karnataka's Queen! 🌺\"\n      }\n    ]\n  },\n  \"ram-prasad-bismil\": {\n    \"name\": \"Ram Prasad Bismil\",\n    \"questions\": [\n      {\n        \"id\": \"rpb_q1\",\n        \"question\": \"Why were you a poet and a warrior?\",\n        \"answer\": \"Because I believed the pen and the sword both serve freedom! My poems inspired thousands of people while my actions showed that I meant every single word I wrote.\",\n        \"badge\": \"Poet Warrior! ✍️\"\n      },\n      {\n        \"id\": \"rpb_q2\",\n        \"question\": \"What is Sarfaroshi ki Tamanna?\",\n        \"answer\": \"It is my most famous poem meaning the desire for revolution burns in our hearts! These words became the anthem of young freedom fighters all across India.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      },\n      {\n        \"id\": \"rpb_q3\",\n        \"question\": \"What were you like as a young man?\",\n        \"answer\": \"I was a deeply passionate young man who felt India's pain in my heart every single day! That pain turned into poetry and that poetry turned into action.\",\n        \"badge\": \"Passionate Soul! 🔥\"\n      },\n      {\n        \"id\": \"rpb_q4\",\n        \"question\": \"What is your biggest legacy?\",\n        \"answer\": \"My poems are still sung today — over 100 years later! Words written with true feeling last forever and continue to inspire people long after the writer is gone.\",\n        \"badge\": \"Eternal Words! 📜\"\n      }\n    ]\n  },\n  \"ashfaqulla-khan\": {\n    \"name\": \"Ashfaqullah Khan\",\n    \"questions\": [\n      {\n        \"id\": \"ak_q1\",\n        \"question\": \"Why is your friendship with Bismil so famous?\",\n        \"answer\": \"Because Ram Prasad Bismil and I were best friends who belonged to different religions but shared one dream — a free India! True friendship knows no religion or caste.\",\n        \"badge\": \"Unity Badge! 🤝\"\n      },\n      {\n        \"id\": \"ak_q2\",\n        \"question\": \"What did you fight for?\",\n        \"answer\": \"I fought for an India where Hindus and Muslims would live together as brothers forever! Unity between all Indians was my deepest dream and my greatest hope.\",\n        \"badge\": \"Unity Hero! 🌈\"\n      },\n      {\n        \"id\": \"ak_q3\",\n        \"question\": \"What were you like as a person?\",\n        \"answer\": \"I was warm, loving and completely devoted to my friends and my country! I believed that the love between friends of different backgrounds is India's true superpower.\",\n        \"badge\": \"Loving Heart! ❤️\"\n      },\n      {\n        \"id\": \"ak_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Be friends with everyone regardless of their religion, language or background! India's greatest strength has always been its beautiful unity in diversity.\",\n        \"badge\": \"Friend of All! 🌟\"\n      }\n    ]\n  },\n  \"sukhdev\": {\n    \"name\": \"Sukhdev Thapar\",\n    \"questions\": [\n      {\n        \"id\": \"st_q1\",\n        \"question\": \"Why are you always with Bhagat Singh?\",\n        \"answer\": \"Because Bhagat Singh and I were inseparable best friends who shared everything — our dreams, our plans and our love for India! The best friendships are built on shared values.\",\n        \"badge\": \"Best Friends! 🤝\"\n      },\n      {\n        \"id\": \"st_q2\",\n        \"question\": \"What did you do for freedom?\",\n        \"answer\": \"I organized revolutionary activities and inspired young people across Punjab to join the freedom movement! One passionate person can light the fire in a thousand hearts.\",\n        \"badge\": \"Organizer! 📣\"\n      },\n      {\n        \"id\": \"st_q3\",\n        \"question\": \"What were you like as a young man?\",\n        \"answer\": \"I was deeply serious about freedom from a very young age! While other young men thought about careers I thought about how to free my beloved country from foreign rule.\",\n        \"badge\": \"Dedicated Soul! 💪\"\n      },\n      {\n        \"id\": \"st_q4\",\n        \"question\": \"What is your biggest lesson?\",\n        \"answer\": \"Choose your friends wisely and stand by them always! Bhagat Singh, Rajguru and I stood together until the very end — that bond of friendship made us stronger than any army.\",\n        \"badge\": \"Loyal Forever! ⭐\"\n      }\n    ]\n  },\n  \"rajguru\": {\n    \"name\": \"Rajguru\",\n    \"questions\": [\n      {\n        \"id\": \"rj_q1\",\n        \"question\": \"Why were you called a sharpshooter?\",\n        \"answer\": \"Because I was extremely skilled and precise in everything I did! Whatever mission I took on for India I gave it my complete focus and energy.\",\n        \"badge\": \"Sharp Focus! 🎯\"\n      },\n      {\n        \"id\": \"rj_q2\",\n        \"question\": \"What did you share with Bhagat Singh?\",\n        \"answer\": \"Bhagat Singh, Sukhdev and I shared everything — our friendship, our mission, our courage and our complete love for India! Together we were unstoppable.\",\n        \"badge\": \"Trio of Heroes! 🔥\"\n      },\n      {\n        \"id\": \"rj_q3\",\n        \"question\": \"What were you like as a young man?\",\n        \"answer\": \"I was energetic, bold and always ready for action! I had trained my body and mind to be completely ready to serve India whenever my country needed me.\",\n        \"badge\": \"Ready Always! ⚡\"\n      },\n      {\n        \"id\": \"rj_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Train yourself every day — your mind, your body and your character! When the moment comes to do something great you want to be completely ready for it.\",\n        \"badge\": \"Be Ready! 💪\"\n      }\n    ]\n  },\n  \"lala-lajpat-rai\": {\n    \"name\": \"Lala Lajpat Rai\",\n    \"questions\": [\n      {\n        \"id\": \"llr_q1\",\n        \"question\": \"Why are you called Punjab Kesari?\",\n        \"answer\": \"Punjab Kesari means Lion of Punjab! I was given this name because I roared like a lion against injustice and never backed down no matter how powerful my opponents were.\",\n        \"badge\": \"Lion of Punjab! 🦁\"\n      },\n      {\n        \"id\": \"llr_q2\",\n        \"question\": \"What happened during the Simon Commission?\",\n        \"answer\": \"I led a peaceful protest against the all-British Simon Commission and was beaten by police. I said every blow they give me will become a nail in the coffin of British rule — and I was right!\",\n        \"badge\": \"Unbreakable Spirit! 💪\"\n      },\n      {\n        \"id\": \"llr_q3\",\n        \"question\": \"What did you do for education?\",\n        \"answer\": \"I believed education was the most powerful weapon for freedom! I started schools and wrote books because I knew an educated India would never accept being ruled by foreigners.\",\n        \"badge\": \"Education Hero! 📚\"\n      },\n      {\n        \"id\": \"llr_q4\",\n        \"question\": \"What is your most famous quote?\",\n        \"answer\": \"I said they may crush my body but not my spirit! No force in the world can defeat a person whose spirit and determination remain completely unbroken.\",\n        \"badge\": \"Battle Cry Learned! 🎤\"\n      }\n    ]\n  },\n  \"bipin-pal\": {\n    \"name\": \"Bipin Chandra Pal\",\n    \"questions\": [\n      {\n        \"id\": \"bcp_q1\",\n        \"question\": \"Who were the Lal Bal Pal trio?\",\n        \"answer\": \"Lala Lajpat Rai, Bal Gangadhar Tilak and I — Bipin Chandra Pal — were three great leaders who together shook the entire British empire with our powerful voices!\",\n        \"badge\": \"Trio of Power! ⚡\"\n      },\n      {\n        \"id\": \"bcp_q2\",\n        \"question\": \"How did you fight for freedom?\",\n        \"answer\": \"I used my powerful speeches and writings to awaken millions of Indians! Words spoken with passion and truth can move mountains and change the course of history.\",\n        \"badge\": \"Word Warrior! 📢\"\n      },\n      {\n        \"id\": \"bcp_q3\",\n        \"question\": \"What did you believe in?\",\n        \"answer\": \"I believed Indians should be completely self-reliant and not depend on the British for anything! True freedom begins when you believe in your own strength and abilities.\",\n        \"badge\": \"Self Reliance! 🌟\"\n      },\n      {\n        \"id\": \"bcp_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Learn to speak up for what you believe in! Your voice is your most powerful gift — use it wisely, use it boldly and use it always in the service of truth.\",\n        \"badge\": \"Speak Up! 🎙️\"\n      }\n    ]\n  },\n  \"aurobindo-ghosh\": {\n    \"name\": \"Aurobindo Ghosh\",\n    \"questions\": [\n      {\n        \"id\": \"ag_q1\",\n        \"question\": \"How were you both a warrior and a saint?\",\n        \"answer\": \"I started as a fierce freedom fighter and later became a great spiritual teacher! I discovered that the inner revolution of the mind is just as important as the outer revolution for freedom.\",\n        \"badge\": \"Warrior Saint! 🌸\"\n      },\n      {\n        \"id\": \"ag_q2\",\n        \"question\": \"What made you so brilliant?\",\n        \"answer\": \"I studied thirteen languages and topped every exam I ever took! But I always believed that wisdom — knowing how to use knowledge — is even more valuable than information alone.\",\n        \"badge\": \"Genius! 🧠\"\n      },\n      {\n        \"id\": \"ag_q3\",\n        \"question\": \"What were you like as a student?\",\n        \"answer\": \"I was an extraordinary student who mastered Greek, Latin and English literature as a young boy in England! I proved that Indian minds are among the finest in the entire world.\",\n        \"badge\": \"Scholar Supreme! 🎓\"\n      },\n      {\n        \"id\": \"ag_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Develop your mind, your heart and your spirit equally! A truly free person is free on the inside as well as the outside — that inner freedom is something nobody can ever take from you.\",\n        \"badge\": \"Inner Freedom! ✨\"\n      }\n    ]\n  },\n  \"veer-savarkar\": {\n    \"name\": \"Vinayak Damodar Savarkar\",\n    \"questions\": [\n      {\n        \"id\": \"vds_q1\",\n        \"question\": \"Why is your escape from a ship famous?\",\n        \"answer\": \"I jumped from a moving ship into the sea and swam to shore to try to escape to freedom! It was one of the most daring escapes in the entire history of India's freedom struggle.\",\n        \"badge\": \"Daring Escape! 🌊\"\n      },\n      {\n        \"id\": \"vds_q2\",\n        \"question\": \"What did you do in prison?\",\n        \"answer\": \"Even in the toughest prison I kept writing poems by scratching them on the prison walls with a thorn! The creative spirit can never be imprisoned no matter what.\",\n        \"badge\": \"Thorn Poet! ✍️\"\n      },\n      {\n        \"id\": \"vds_q3\",\n        \"question\": \"What were you like as a young man?\",\n        \"answer\": \"I was an extremely passionate and daring young man who organized revolutionary activities even as a student! My fearlessness inspired countless young Indians to join the freedom movement.\",\n        \"badge\": \"Student Rebel! 🔥\"\n      },\n      {\n        \"id\": \"vds_q4\",\n        \"question\": \"What is your biggest legacy?\",\n        \"answer\": \"I showed that the creative mind and the brave heart together can overcome any obstacle! Even the most powerful prison could not silence my voice or stop my pen.\",\n        \"badge\": \"Unstoppable! 💪\"\n      }\n    ]\n  },\n  \"uyyalawada-narasimha-reddy\": {\n    \"name\": \"Uyyalawada Narasimha Reddy\",\n    \"questions\": [\n      {\n        \"id\": \"unr_q1\",\n        \"question\": \"Why are you called the first rebel?\",\n        \"answer\": \"Because I stood up against the British in 1846 — over ten years before the famous revolt of 1857! Being first takes extraordinary courage when nobody else has done it before.\",\n        \"badge\": \"First Rebel! ⚔️\"\n      },\n      {\n        \"id\": \"unr_q2\",\n        \"question\": \"What did you fight for?\",\n        \"answer\": \"I fought for the farmers and poor people of Andhra Pradesh whose lands were being taken away by the British! Protecting the helpless is the highest duty of any leader.\",\n        \"badge\": \"Farmers Friend! 🌾\"\n      },\n      {\n        \"id\": \"unr_q3\",\n        \"question\": \"Why is Andhra Pradesh proud of you?\",\n        \"answer\": \"Because I showed that the spirit of resistance against injustice was burning in South India long before many people knew about it! Every region of India has its early heroes.\",\n        \"badge\": \"Andhra's Pride! 🌺\"\n      },\n      {\n        \"id\": \"unr_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Do not wait for someone else to stand up first! Be the one who starts the change even if you stand alone at the beginning — others will follow your brave example.\",\n        \"badge\": \"Stand First! 🌟\"\n      }\n    ]\n  },\n  \"tara-rani-srivastava\": {\n    \"name\": \"Tara Rani Srivastava\",\n    \"questions\": [\n      {\n        \"id\": \"trs_q1\",\n        \"question\": \"What makes your story so touching?\",\n        \"answer\": \"My husband was hurt during our freedom march but I bandaged his wounds, told him to rest and carried on marching with the flag myself! India's freedom was bigger than any personal grief.\",\n        \"badge\": \"Unshakeable! 🇮🇳\"\n      },\n      {\n        \"id\": \"trs_q2\",\n        \"question\": \"How did you show such strength?\",\n        \"answer\": \"I found strength in my love for India! When your purpose is bigger than yourself you discover a courage and strength inside you that you never knew was there.\",\n        \"badge\": \"Inner Strength! 💪\"\n      },\n      {\n        \"id\": \"trs_q3\",\n        \"question\": \"Why do we remember you?\",\n        \"answer\": \"Because I showed that ordinary Indian women had extraordinary courage! I was not a queen or a princess — I was a common woman who did an uncommon thing.\",\n        \"badge\": \"Common Hero! ⭐\"\n      },\n      {\n        \"id\": \"trs_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Even in your saddest moments you can find the strength to keep going for something you truly love! Grief and courage can exist in the same heart at the same time.\",\n        \"badge\": \"Keep Going! 🌸\"\n      }\n    ]\n  },\n  \"abbakka-chowta\": {\n    \"name\": \"Abbakka Chowta\",\n    \"questions\": [\n      {\n        \"id\": \"ac_q1\",\n        \"question\": \"How many times did you defeat the Portuguese?\",\n        \"answer\": \"I defeated the Portuguese not once, not twice but four times! Each victory showed that a determined defender can beat a much more powerful invader again and again.\",\n        \"badge\": \"Four Time Winner! 🏆\"\n      },\n      {\n        \"id\": \"ac_q2\",\n        \"question\": \"Why are you called the Fearless Queen?\",\n        \"answer\": \"Because I led my soldiers personally into battle on the beaches of Ullal! A fearless leader who fights alongside their people inspires ten times the courage in every soldier.\",\n        \"badge\": \"Fearless Queen! 👑\"\n      },\n      {\n        \"id\": \"ac_q3\",\n        \"question\": \"What made you special as a ruler?\",\n        \"answer\": \"I formed alliances with neighbouring kingdoms and local communities to fight together! I understood that unity and cooperation are far stronger than any single warrior alone.\",\n        \"badge\": \"Alliance Builder! 🤝\"\n      },\n      {\n        \"id\": \"ac_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Never be intimidated by someone bigger or more powerful than you! I faced the mighty Portuguese navy with a small coastal kingdom — and I won because I was smarter and braver.\",\n        \"badge\": \"David vs Goliath! ⚡\"\n      }\n    ]\n  },\n  \"puli-thevar\": {\n    \"name\": \"Puli Thevar\",\n    \"questions\": [\n      {\n        \"id\": \"pt_q1\",\n        \"question\": \"Why are you the first rebel of South India?\",\n        \"answer\": \"Because I was one of the very first rulers in South India to directly confront the British East India Company! Standing up first when everyone is silent is the bravest act of all.\",\n        \"badge\": \"South India's First! 🌟\"\n      },\n      {\n        \"id\": \"pt_q2\",\n        \"question\": \"What did Puli mean?\",\n        \"answer\": \"Puli means Tiger in Tamil! I was given this name because of my fierce and fearless nature — like a tiger I protected my territory and my people with absolute ferocity.\",\n        \"badge\": \"Tiger Spirit! 🐯\"\n      },\n      {\n        \"id\": \"pt_q3\",\n        \"question\": \"What did you fight to protect?\",\n        \"answer\": \"I fought to protect the independence and dignity of my kingdom Nerkattumseval in Tamil Nadu! Every inch of India's soil is worth protecting with everything you have.\",\n        \"badge\": \"Territory Guardian! 🛡️\"\n      },\n      {\n        \"id\": \"pt_q4\",\n        \"question\": \"What is Tamil Nadu's pride in you?\",\n        \"answer\": \"I am remembered as a pioneering freedom fighter who showed that Tamil people would never accept foreign domination! Tamil Nadu's spirit of independence goes back centuries.\",\n        \"badge\": \"Tamil Tiger! 🌺\"\n      }\n    ]\n  },\n  \"kushal-konwar\": {\n    \"name\": \"Kushal Konwar\",\n    \"questions\": [\n      {\n        \"id\": \"kk_q1\",\n        \"question\": \"Why is Assam so proud of you?\",\n        \"answer\": \"Because I gave my life for India's freedom and became Assam's greatest martyr! Every state in India has heroes who gave everything — knowing them makes us truly understand our freedom.\",\n        \"badge\": \"Assam's Pride! 🌿\"\n      },\n      {\n        \"id\": \"kk_q2\",\n        \"question\": \"What did you do for freedom?\",\n        \"answer\": \"I was deeply involved in the Quit India Movement of 1942 when millions of Indians rose up together and said loudly — British must leave India now!\",\n        \"badge\": \"Quit India Hero! 🇮🇳\"\n      },\n      {\n        \"id\": \"kk_q3\",\n        \"question\": \"What were you like as a person?\",\n        \"answer\": \"I was a calm and deeply principled man who believed strongly in doing what was right! Quiet people with strong principles often make the most lasting impact on history.\",\n        \"badge\": \"Principled Soul! ⭐\"\n      },\n      {\n        \"id\": \"kk_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Remember the heroes of your own state and city — not just the famous national leaders! Every corner of India has brave people whose stories deserve to be heard and celebrated.\",\n        \"badge\": \"Local Heroes Matter! 🏅\"\n      }\n    ]\n  },\n  \"bhima-bhoi\": {\n    \"name\": \"Bhima Bhoi\",\n    \"questions\": [\n      {\n        \"id\": \"bb_q1\",\n        \"question\": \"How did you inspire people even though you were blind?\",\n        \"answer\": \"I could not see with my eyes but I saw the truth in my heart! My poems and songs opened the eyes of thousands of people and inspired them to fight for justice and freedom.\",\n        \"badge\": \"Inner Vision! 👁️\"\n      },\n      {\n        \"id\": \"bb_q2\",\n        \"question\": \"What did your poems say?\",\n        \"answer\": \"My poems said that every human being deserves dignity and freedom regardless of who they are! I believed in equality for all people long before it became a common idea.\",\n        \"badge\": \"Equality Hero! 🌈\"\n      },\n      {\n        \"id\": \"bb_q3\",\n        \"question\": \"What makes your story special?\",\n        \"answer\": \"I proved that physical limitations can never limit the power of your spirit and mind! I could not see yet I created beautiful works that moved an entire generation of people.\",\n        \"badge\": \"Spirit Unbound! ✨\"\n      },\n      {\n        \"id\": \"bb_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Never let any challenge or difficulty make you feel less capable! Your mind, your heart and your spirit are your greatest gifts — and nobody can ever take them from you.\",\n        \"badge\": \"Limitless! 🌟\"\n      }\n    ]\n  },\n  \"subramania-bharati\": {\n    \"name\": \"Subramania Bharati\",\n    \"questions\": [\n      {\n        \"id\": \"sb_q1\",\n        \"question\": \"Why are you called Bharati the Great?\",\n        \"answer\": \"Because my Tamil poems were so beautiful and powerful that they inspired an entire generation of freedom fighters! Poetry that touches the soul is one of the most powerful forces for change.\",\n        \"badge\": \"Tamil Poet! 🎵\"\n      },\n      {\n        \"id\": \"sb_q2\",\n        \"question\": \"What did your poems talk about?\",\n        \"answer\": \"I wrote about freedom, women's rights, unity among Indians and the beauty of India! I believed poetry should not just be beautiful — it should also make people think and act.\",\n        \"badge\": \"Poet of Change! ✍️\"\n      },\n      {\n        \"id\": \"sb_q3\",\n        \"question\": \"What were you like as a child?\",\n        \"answer\": \"I was a child prodigy who was writing beautiful Tamil poetry by the age of 11! The community recognised my talent and gave me the title Bharati meaning blessed with brilliance.\",\n        \"badge\": \"Child Poet! ⭐\"\n      },\n      {\n        \"id\": \"sb_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Express yourself through art, music, writing or whatever creative form you love! Creativity is not just a hobby — it is a powerful way to change hearts and change the world.\",\n        \"badge\": \"Create Change! 🌟\"\n      }\n    ]\n  },\n  \"tilka-manjhi\": {\n    \"name\": \"Tantya Bhil\",\n    \"questions\": [\n      {\n        \"id\": \"tb_q1\",\n        \"question\": \"Why do people call you Robin Hood of India?\",\n        \"answer\": \"Because I took from the rich British rulers and gave to the poor tribal people who were starving! I believed that wealth stolen from the poor must be returned to them.\",\n        \"badge\": \"Robin Hood! 🏹\"\n      },\n      {\n        \"id\": \"tb_q2\",\n        \"question\": \"Who did you fight for?\",\n        \"answer\": \"I fought for the poor Bhil tribal people of Madhya Pradesh whose lives were being destroyed by unfair British taxes and laws! Standing for the poorest people is the noblest cause.\",\n        \"badge\": \"Poor People's Hero! 🌿\"\n      },\n      {\n        \"id\": \"tb_q3\",\n        \"question\": \"What made you impossible to catch?\",\n        \"answer\": \"I knew the jungles and hills of my region better than anyone alive! When you know your home ground completely it becomes your greatest protection and your most powerful weapon.\",\n        \"badge\": \"Jungle Master! 🌳\"\n      },\n      {\n        \"id\": \"tb_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Always share with those who have less than you and stand up for those who are being treated unfairly! The measure of a great person is how they treat the most vulnerable people around them.\",\n        \"badge\": \"Share and Care! ❤️\"\n      }\n    ]\n  },\n  \"aruna-asaf-ali\": {\n    \"name\": \"Aruna Asaf Ali\",\n    \"questions\": [\n      {\n        \"id\": \"aaa_q1\",\n        \"question\": \"Why are you called the Grand Old Lady of India?\",\n        \"answer\": \"Because I served India with complete dedication from my youth until my very old age! I proved that the love of country and the desire to serve never diminish with time.\",\n        \"badge\": \"Grand Legacy! 👑\"\n      },\n      {\n        \"id\": \"aaa_q2\",\n        \"question\": \"What did you do in the Quit India Movement?\",\n        \"answer\": \"I hoisted the Indian National Flag at Gowalia Tank in Mumbai in 1942 which became one of the most iconic moments of the entire freedom struggle! One brave act can inspire a nation.\",\n        \"badge\": \"Flag Moment! 🇮🇳\"\n      },\n      {\n        \"id\": \"aaa_q3\",\n        \"question\": \"What were you like as a young woman?\",\n        \"answer\": \"I was fearless and refused to follow rules that I believed were unjust! Even when the British put a price on my head I continued working for India's freedom from hiding.\",\n        \"badge\": \"Fearless Woman! 🔥\"\n      },\n      {\n        \"id\": \"aaa_q4\",\n        \"question\": \"What is your message for girls?\",\n        \"answer\": \"Do not be afraid to stand in the front row and take action! Women have always been at the heart of India's greatest moments — your place is always at the centre of the action.\",\n        \"badge\": \"Front Row! 🌟\"\n      }\n    ]\n  },\n  \"bagha-jatin\": {\n    \"name\": \"Bagha Jatin\",\n    \"questions\": [\n      {\n        \"id\": \"bj_q1\",\n        \"question\": \"Why are you called Bagha Jatin?\",\n        \"answer\": \"Bagha means Tiger! I earned this name because I once fought a Royal Bengal Tiger with my bare hands to protect villagers. After that everyone called me the Tiger Man of Bengal!\",\n        \"badge\": \"Tiger Man! 🐯\"\n      },\n      {\n        \"id\": \"bj_q2\",\n        \"question\": \"What did you do for freedom?\",\n        \"answer\": \"I led the revolutionary movement in Bengal and organised brave young Indians to fight for independence! I believed that a free India was worth every sacrifice a person could make.\",\n        \"badge\": \"Bengal's Lion! 🔥\"\n      },\n      {\n        \"id\": \"bj_q3\",\n        \"question\": \"What were you like as a young man?\",\n        \"answer\": \"I was incredibly strong, fearless and deeply kind at the same time! I trained my body to be powerful but always used my strength to protect others rather than to harm anyone.\",\n        \"badge\": \"Strong and Kind! 💪\"\n      },\n      {\n        \"id\": \"bj_q4\",\n        \"question\": \"What is your biggest lesson for kids?\",\n        \"answer\": \"True strength is always used to protect others never to frighten them! Build yourself strong in body and mind — then use that strength in the service of people who need you.\",\n        \"badge\": \"Strength with Heart! ❤️\"\n      }\n    ]\n  },\n  \"bhimrao-ambedkar\": {\n    \"name\": \"Dr. B.R. Ambedkar\",\n    \"questions\": [\n      {\n        \"id\": \"bra_q1\",\n        \"question\": \"What is the Constitution of India?\",\n        \"answer\": \"The Constitution is the most important rulebook of our country — it tells us the rights every Indian has and how our government must work! I wrote it and it protects every single one of you.\",\n        \"badge\": \"Constitution Maker! 📜\"\n      },\n      {\n        \"id\": \"bra_q2\",\n        \"question\": \"Why did you fight so hard for equal rights?\",\n        \"answer\": \"Because I believed every single Indian deserves to be treated with dignity and respect no matter who they are or where they come from! Equality is not a gift — it is every person's birthright.\",\n        \"badge\": \"Equality Champion! ⚖️\"\n      },\n      {\n        \"id\": \"bra_q3\",\n        \"question\": \"What were you like as a student?\",\n        \"answer\": \"I faced many difficulties as a child but I never stopped studying! I became one of the most educated people in the entire world — with degrees from the best universities in India, America and England.\",\n        \"badge\": \"Education Hero! 🎓\"\n      },\n      {\n        \"id\": \"bra_q4\",\n        \"question\": \"What is your message for every child in India?\",\n        \"answer\": \"Educate yourself, organise with others and never stop fighting for justice! I rose from very difficult circumstances to write the rules that protect all Indians — and so can you.\",\n        \"badge\": \"Jai Bhim! 🌟\"\n      }\n    ]\n  },\n  \"kalpana-datta\": {\n    \"name\": \"Kalpana Datta\",\n    \"questions\": [\n      {\n        \"id\": \"kd_q1\",\n        \"question\": \"What made you join the freedom movement?\",\n        \"answer\": \"I was a young college student who felt so strongly about India's freedom that I put down my books and picked up the cause! I believed young people had a special duty to act.\",\n        \"badge\": \"Student Fighter! 📚\"\n      },\n      {\n        \"id\": \"kd_q2\",\n        \"question\": \"Who did you fight alongside?\",\n        \"answer\": \"I fought alongside the great Surya Sen and his brave group of revolutionaries in Chittagong! Working with determined people multiplies your own strength and courage many times over.\",\n        \"badge\": \"Brave Companion! 🤝\"\n      },\n      {\n        \"id\": \"kd_q3\",\n        \"question\": \"What were you like as a young woman?\",\n        \"answer\": \"I was bold, determined and completely unafraid! At a time when many thought women should stay home I went out and fought for India with the same fire as any man.\",\n        \"badge\": \"Fearless Woman! 🔥\"\n      },\n      {\n        \"id\": \"kd_q4\",\n        \"question\": \"What is your message for girls?\",\n        \"answer\": \"Never let anyone decide your boundaries for you! I was a girl from Bengal who took on the British Empire — your dreams and your courage have absolutely no limits.\",\n        \"badge\": \"No Limits! 🌟\"\n      }\n    ]\n  },\n  \"khudiram-bose\": {\n    \"name\": \"Khudiram Bose\",\n    \"questions\": [\n      {\n        \"id\": \"kb_q1\",\n        \"question\": \"How old were you when you became a freedom fighter?\",\n        \"answer\": \"I was just 15 years old when I first joined the freedom movement and only 18 when I gave my life for India! Age is never a barrier when love for your country is in your heart.\",\n        \"badge\": \"Youngest Martyr! ⭐\"\n      },\n      {\n        \"id\": \"kb_q2\",\n        \"question\": \"What made you so fearless at such a young age?\",\n        \"answer\": \"I believed so completely in India's freedom that fear simply had no place in my heart! When your purpose is clear and your love is true nothing in the world can make you afraid.\",\n        \"badge\": \"Pure Courage! 🔥\"\n      },\n      {\n        \"id\": \"kb_q3\",\n        \"question\": \"What were you like as a teenager?\",\n        \"answer\": \"I was a passionate and determined teenager who distributed revolutionary pamphlets and refused to be scared by British policemen! I believed young people could change history.\",\n        \"badge\": \"Teen Revolutionary! 💪\"\n      },\n      {\n        \"id\": \"kb_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"You are never too young to love your country and do something meaningful for it! I was a teenager just like you will be — and I showed the world what a young Indian heart is made of.\",\n        \"badge\": \"Young and Brave! 🇮🇳\"\n      }\n    ]\n  },\n  \"madam-cama\": {\n    \"name\": \"Madam Bhikaji Cama\",\n    \"questions\": [\n      {\n        \"id\": \"mc_q1\",\n        \"question\": \"What amazing thing did you do in Germany?\",\n        \"answer\": \"I unfurled the Indian national flag at an international conference in Stuttgart Germany in 1907 — the very first time our flag was ever waved on foreign soil! That moment gave India's struggle a global voice.\",\n        \"badge\": \"First Flag Abroad! 🇮🇳\"\n      },\n      {\n        \"id\": \"mc_q2\",\n        \"question\": \"Why do you call yourself Mother India?\",\n        \"answer\": \"Because I dedicated my entire life to India's freedom even while living abroad in Europe! A true mother protects and fights for her children from anywhere in the world.\",\n        \"badge\": \"Mother India! 🌸\"\n      },\n      {\n        \"id\": \"mc_q3\",\n        \"question\": \"What were you like as a freedom fighter?\",\n        \"answer\": \"I was bold, articulate and completely passionate about making the whole world hear India's voice! I travelled across Europe telling everyone about the injustice of British rule in India.\",\n        \"badge\": \"Global Voice! 📢\"\n      },\n      {\n        \"id\": \"mc_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"You can fight for your country from anywhere in the world! Love for India is not limited by distance — carry your country in your heart wherever life takes you.\",\n        \"badge\": \"India Everywhere! 🌍\"\n      }\n    ]\n  },\n  \"surya-sen\": {\n    \"name\": \"Surya Sen\",\n    \"questions\": [\n      {\n        \"id\": \"ss_q1\",\n        \"question\": \"Why are you called Master Da?\",\n        \"answer\": \"Because I was a beloved school teacher before becoming a freedom fighter! My students called me Master Da which means respected teacher — and I tried to teach courage as well as lessons.\",\n        \"badge\": \"Teacher Hero! 📚\"\n      },\n      {\n        \"id\": \"ss_q2\",\n        \"question\": \"What was the Chittagong Armoury Raid?\",\n        \"answer\": \"I led a brave group of young Indians who raided the British armoury in Chittagong in 1930! It was one of the most daring acts of the entire freedom struggle — a small group taking on a mighty empire.\",\n        \"badge\": \"Daring Raid! ⚔️\"\n      },\n      {\n        \"id\": \"ss_q3\",\n        \"question\": \"What were you like as a teacher?\",\n        \"answer\": \"I inspired my students not just with books but with the fire of patriotism! I believed the greatest lesson a teacher can give is the courage to stand up for what is right.\",\n        \"badge\": \"Inspiring Teacher! 🌟\"\n      },\n      {\n        \"id\": \"ss_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Your teachers can be your greatest heroes — listen to them with your whole heart! And remember that knowledge combined with courage is the most powerful combination in the world.\",\n        \"badge\": \"Learn and Be Brave! 💪\"\n      }\n    ]\n  },\n  \"velu-thampi\": {\n    \"name\": \"Velu Thampi Dalawa\",\n    \"questions\": [\n      {\n        \"id\": \"vtd_q1\",\n        \"question\": \"Who were you?\",\n        \"answer\": \"I was the Prime Minister of the kingdom of Travancore in Kerala — and I refused to let the British take over our beautiful land! I stood up for Kerala's independence with every breath I took.\",\n        \"badge\": \"Kerala's Guardian! 🥥\"\n      },\n      {\n        \"id\": \"vtd_q2\",\n        \"question\": \"What is the Kundara Proclamation?\",\n        \"answer\": \"It was my powerful declaration calling all people of Kerala to rise up and fight against British interference in our kingdom! It was one of the earliest calls to armed resistance in all of South India.\",\n        \"badge\": \"First Call! 📜\"\n      },\n      {\n        \"id\": \"vtd_q3\",\n        \"question\": \"What made you a great leader?\",\n        \"answer\": \"I was an extremely skilled administrator who also had the courage to fight when diplomacy failed! The best leaders know when to talk and when to take a firm stand for their people.\",\n        \"badge\": \"Wise and Bold! 👑\"\n      },\n      {\n        \"id\": \"vtd_q4\",\n        \"question\": \"What is your message for kids?\",\n        \"answer\": \"Be proud of your home state and learn about its local heroes! Kerala has a magnificent history of brave people — knowing your roots makes you stronger and more confident.\",\n        \"badge\": \"Know Your Roots! 🌿\"\n      }\n    ]\n  }\n};\n});","lineCount":1338,"map":[[1338,3]],"functionMap":null},"type":"js/module"}]}